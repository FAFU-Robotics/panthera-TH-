# =============================================================================
#  99-panthera-debug-board.rules
#
#  把调试板 USB 串口固定到 /dev/panthera_debug_board, 并设置全用户可读写,
#  这样:
#    - robot.cfg 里写 port = /dev/panthera_debug_board, 换 USB 口不用改配置
#    - 不需要 sudo 就能打开串口 (不用每次 chmod 666 /dev/ttyUSB0)
#    - 即使没有把用户加入 dialout 组, 也能用 (MODE=0666)
#
#  支持的 USB VID (常见调试板用的 USB-Serial 桥芯片):
#    0483  ST Micro (STM32 内置 USB-CDC) ← Panthera-HT 调试板用这个
#    0403  FTDI
#    1A86  WinChipHead (CH340/CH341)
#    10C4  Silicon Labs (CP2102/CP2104)
#    067B  Prolific (PL2303)
#
#  如果你的调试板 VID 不在上面, 用下面命令查:
#      lsusb            # 找到调试板那一行, 看 ID 字段, 前 4 位是 VID
#      udevadm info -a -n /dev/ttyUSB0 | grep idVendor
#
#  安装:
#      sudo cp linux/99-panthera-debug-board.rules /etc/udev/rules.d/
#      sudo udevadm control --reload
#      sudo udevadm trigger
#  (或直接跑 bash linux/setup_udev.sh, 自动做这些)
# =============================================================================

# --- ST Micro (STM32 USB-CDC) ---
SUBSYSTEM=="tty", ATTRS{idVendor}=="0483", MODE="0666", GROUP="dialout", SYMLINK+="panthera_debug_board", TAG+="uaccess"

# --- FTDI ---
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", MODE="0666", GROUP="dialout", SYMLINK+="panthera_debug_board", TAG+="uaccess"

# --- CH340 / CH341 ---
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", MODE="0666", GROUP="dialout", SYMLINK+="panthera_debug_board", TAG+="uaccess"

# --- Silicon Labs CP210x ---
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", MODE="0666", GROUP="dialout", SYMLINK+="panthera_debug_board", TAG+="uaccess"

# --- Prolific PL2303 ---
SUBSYSTEM=="tty", ATTRS{idVendor}=="067b", MODE="0666", GROUP="dialout", SYMLINK+="panthera_debug_board", TAG+="uaccess"

# 说明:
#   MODE=0666       — 任何用户都能读写, 不必加 dialout 组
#   GROUP=dialout   — 双保险, 已在 dialout 组的用户也能正常工作
#   SYMLINK         — 创建固定路径 /dev/panthera_debug_board → /dev/ttyUSBx
#   TAG=uaccess     — systemd-logind 会授给"当前登录用户"独占访问 (POLKIT)
