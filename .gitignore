# =============================================================================
# Panthera_Workspace .gitignore
# 说明:
#   - panthera_web/panthera_motor.cp*-win_amd64.pyd 与 panthera_web/serial_cmake.dll
#     是项目运行时分发产物 (放在 panthera_web 根目录), 仍然纳入版本管理.
#   - fafu_robot_sdk/fafu_robot_python/panthera_motor.cp*-win_amd64.pyd 与对应
#     serial_cmake.dll 同理 (放在 SDK Python 包根目录), 纳入版本管理.
#   - panthera_web/build/ 与 fafu_robot_sdk/fafu_robot_cpp/build/ 下的中间产物全部忽略.
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*$py.class

# ---- 构建目录 (含 build/, build310/, build_linux/ 等带后缀变体) ----
build/
build[_0-9]*/
**/build/
**/build[_0-9]*/

# ---- MSVC / CMake 中间产物 ----
*.obj
*.iobj
*.ipdb
*.pdb
*.idb
*.ilk
*.exp
*.tlog
*.recipe
*.lastbuildstate
*.unsuccessfulbuild

# ---- IDE / 编辑器 ----
.vs/
.vscode/
.idea/
*.suo
*.user
*.ncb
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
*.code-workspace

# ---- 日志 / 临时 ----
*.log
*.tmp
*.bak
*.swp
*.swo
*~

# ---- 操作系统 ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---- AI / Cursor / Claude ----
.claude/
*.claude

# ---- 不再跟踪的运行日志 ----
panthera_web/last_run.log

# ---- 备份压缩包 (源码已在仓库里, 不需要再存 zip) ----
fafu_robot_sdk/fafu_robot_python.zip

# ---- 反规则: SDK 运行时分发产物保留 (绕开上面 *.py[cod] 把 .pyd 误命中) ----
!fafu_robot_sdk/fafu_robot_python/panthera_motor.cp*-win_amd64.pyd
!panthera_web/panthera_motor.cp*-win_amd64.pyd
